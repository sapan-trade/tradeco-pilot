# Postgres (matches docker-compose.yml)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/tradeco?schema=public
# App URL used in Stripe redirect URLs and Shopify OAuth callback
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Clerk — wired in production. Webhook handler accepts unverified payloads in dev when unset.
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SECRET=
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=

# AI — Phase 1 uses deterministic stub. Setting USE_REAL_AI=1 logs a warning and still falls back to stub.
ANTHROPIC_API_KEY=
USE_REAL_AI=0

# Inngest — declarative cron; events only fire in prod when keys are set.
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# Stripe — leave STRIPE_SECRET_KEY unset to use the stub client (tests do this).
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_GROWTH=
STRIPE_PRICE_PRO=

# Shopify — leave unset to use the stub connector (3 synthetic products).
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=

# Object storage — when AWS_S3_BUCKET is unset, presign URLs use the in-memory store
# served by /api/connectors/upload/put.
AWS_S3_BUCKET=
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Upstash Redis (rate limit). Unset = in-memory bucket per process.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Sentry. Unset = console-only error capture.
SENTRY_DSN=
